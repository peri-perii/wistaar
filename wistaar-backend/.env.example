# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=wistaar_user
DB_PASSWORD=your_password_here
DB_NAME=wistaar_db

# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Configuration (SendGrid or similar)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@wistaar.com
EMAIL_FROM_NAME=Wistaar

# Email Verification
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Payment Gateway (PayU)
PAYU_MERCHANT_ID=your_payu_merchant_id
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_salt

# Stripe (Alternative)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# AWS S3 (For file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=wistaar-bucket

# Logging
LOG_LEVEL=info
