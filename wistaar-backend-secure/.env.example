# Database
DATABASE_URL="mysql://username:password@localhost:3306/wistaar_db?sslaccept=strict"
DB_READ_REPLICA_URL="mysql://readonly_user:password@localhost:3306/wistaar_db?sslaccept=strict"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-access-token-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-jwt-refresh-token-key-min-32-chars"

# Encryption
ENCRYPTION_KEY="your-32-byte-hex-encoded-aes-256-key-exactly-64-hex-chars"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
S3_BUCKET_NAME="wistaar-manuscripts-and-covers"

# Razorpay Payment Gateway
RAZORPAY_KEY_ID="rzp_live_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# Server
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Logging
LOG_LEVEL="debug"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5

# File Upload
MAX_FILE_SIZE_MANUSCRIPT=209715200
MAX_FILE_SIZE_COVER=5242880

# SMTP (Email Service)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@wistaar.com"

# Account Lockout
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=1800000

# Socket.io
SOCKET_CORS_ORIGIN="http://localhost:5173"

# Stripe (Alternative Payment)
STRIPE_SECRET_KEY="sk_live_xxxxx"
STRIPE_PUBLISHABLE_KEY="pk_live_xxxxx"

# ClamAV (Virus Scanning)
CLAMAV_HOST="localhost"
CLAMAV_PORT=3310

# Redis (Optional - for session caching)
REDIS_URL="redis://localhost:6379"
