# ─────────────────────────────────────────────────────────────
# Wistaar Backend — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────

# Database
DATABASE_URL="mysql://YOUR_DB_USER:YOUR_DB_PASS@YOUR_DB_HOST:3306/YOUR_DB_NAME?sslaccept=strict"
DB_READ_REPLICA_URL="mysql://YOUR_READONLY_USER:YOUR_READONLY_PASS@YOUR_DB_HOST:3306/YOUR_DB_NAME?sslaccept=strict"

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_RANDOM_64_CHAR_HEX_STRING"

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_HEX_ENCODED_AES_256_KEY"

# AWS S3 — https://console.aws.amazon.com/iam
AWS_REGION="YOUR_AWS_REGION"
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
S3_BUCKET_NAME="YOUR_S3_BUCKET_NAME"

# Razorpay Payment Gateway — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY_ID"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_KEY_SECRET"

# Server
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Logging (debug | info | warn | error)
LOG_LEVEL="debug"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5

# File Upload (bytes)
MAX_FILE_SIZE_MANUSCRIPT=209715200
MAX_FILE_SIZE_COVER=5242880

# SMTP (Email Service) — use your email provider's SMTP settings
SMTP_HOST="YOUR_SMTP_HOST"
SMTP_PORT=587
SMTP_USER="YOUR_SMTP_USERNAME"
SMTP_PASS="YOUR_SMTP_PASSWORD"
SMTP_FROM="YOUR_FROM_ADDRESS"

# Account Lockout
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=1800000

# Socket.io CORS
SOCKET_CORS_ORIGIN="http://localhost:5173"

# Stripe (Alternative Payment) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"
STRIPE_PUBLISHABLE_KEY="YOUR_STRIPE_PUBLISHABLE_KEY"

# ClamAV (Virus Scanning)
CLAMAV_HOST="YOUR_CLAMAV_HOST"
CLAMAV_PORT=3310

# Redis (Optional — for session caching)
REDIS_URL="redis://YOUR_REDIS_HOST:6379"
