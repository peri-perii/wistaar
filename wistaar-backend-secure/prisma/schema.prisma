// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// AUTH & USER MANAGEMENT
// ============================================================

model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  passwordHash          String
  emailVerified         Boolean     @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  isActive              Boolean     @default(true)
  isLocked              Boolean     @default(false)
  failedLoginAttempts   Int         @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relations
  profile               Profile?
  roles                 UserRole[]
  bookSubmissions       BookSubmission[]
  bookPurchases         BookPurchase[]
  cartItems             CartItem[]
  bookReviews           BookReview[]
  readingProgress       ReadingProgress[]
  wishlists             Wishlist[]
  bookmarks             Bookmark[]
  notifications         Notification[]
  appliedCoupons        AppliedCoupon[]

  @@index([email])
  @@index([createdAt])
}

model UserRole {
  id                    String      @id @default(cuid())
  userId                String
  role                  Role        @default(USER)
  createdAt             DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
}

enum Role {
  ADMIN
  AUTHOR
  USER
}

model Profile {
  id                    String      @id @default(cuid())
  userId                String      @unique
  displayName           String?
  bio                   String?     @db.Text
  avatarUrl             String?
  avatarBlob            Bytes?      @db.LongBlob
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// BOOKS & SUBMISSIONS
// ============================================================

model BookSubmission {
  id                    String      @id @default(cuid())
  authorId              String
  title                 String
  description           String      @db.Text
  genre                 String
  price                 Decimal     @default(0) @db.Decimal(10, 2)
  coverImageUrl         String?
  coverImageBlob        Bytes?      @db.LongBlob
  manuscriptUrl         String?
  manuscriptBlob        Bytes?      @db.LongBlob
  status                SubmissionStatus @default(PENDING)
  adminFeedback         String?     @db.Text
  totalChapters         Int         @default(0)
  submittedAt           DateTime    @default(now())
  reviewedAt            DateTime?
  reviewedBy            String?
  updatedAt             DateTime    @updatedAt

  // Relations
  author                User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  chapters              BookChapter[]
  purchases             BookPurchase[]
  reviews               BookReview[]
  readingProgress       ReadingProgress[]
  wishlists             Wishlist[]
  cartItems             CartItem[]

  @@index([authorId])
  @@index([status])
  @@index([genre])
  @@index([createdAt])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model BookChapter {
  id                    String      @id @default(cuid())
  bookId                String
  chapterNumber         Int
  title                 String
  content               String      @db.LongText
  wordCount             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  book                  BookSubmission @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, chapterNumber])
  @@index([bookId])
}

// ============================================================
// PURCHASES & PAYMENTS
// ============================================================

model BookPurchase {
  id                    String      @id @default(cuid())
  userId                String
  bookId                String
  amount                Decimal     @db.Decimal(10, 2)
  transactionId         String?
  paymentStatus         PaymentStatus @default(PENDING)
  payuTxnId             String?
  receiptBlob           Bytes?      @db.LongBlob
  purchasedAt           DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                  BookSubmission @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
  @@index([paymentStatus])
  @@index([purchasedAt])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model CartItem {
  id                    String      @id @default(cuid())
  userId                String
  bookId                String
  addedAt               DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                  BookSubmission @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
}

// ============================================================
// COUPONS & DISCOUNTS
// ============================================================

model Coupon {
  id                    String      @id @default(cuid())
  code                  String      @unique
  discountPercentage    Int         @default(0)
  discountAmount        Decimal?    @db.Decimal(10, 2)
  maximumDiscount       Decimal?    @db.Decimal(10, 2)
  isActive              Boolean     @default(true)
  minimumPurchaseAmount Decimal?    @db.Decimal(10, 2)
  expiryDate            DateTime?
  maxUsageCount         Int?
  currentUsageCount     Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  appliedCoupons        AppliedCoupon[]

  @@index([code])
  @@index([isActive])
}

model AppliedCoupon {
  id                    String      @id @default(cuid())
  userId                String
  couponId              String
  appliedAt             DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon                Coupon      @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@index([userId])
}

// ============================================================
// READING & ENGAGEMENT
// ============================================================

model BookReview {
  id                    String      @id @default(cuid())
  userId                String
  bookId                String
  rating                Int         @default(5)
  reviewText            String?     @db.Text
  isApproved            Boolean     @default(false)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                  BookSubmission @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
  @@index([rating])
}

model ReadingProgress {
  id                    String      @id @default(cuid())
  userId                String
  bookId                String
  currentChapter        Int         @default(0)
  currentPage           Int         @default(0)
  percentageRead        Decimal     @default(0) @db.Decimal(5, 2)
  isBookmarked          Boolean     @default(false)
  lastReadAt            DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                  BookSubmission @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model Bookmark {
  id                    String      @id @default(cuid())
  userId                String
  bookId                String
  chapterNumber         Int
  pageNumber            Int?
  markedAt              DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId, chapterNumber])
  @@index([userId])
}

model Wishlist {
  id                    String      @id @default(cuid())
  userId                String
  bookId                String
  addedAt               DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                  BookSubmission @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

// ============================================================
// NOTIFICATIONS & COMMUNICATION
// ============================================================

model Notification {
  id                    String      @id @default(cuid())
  userId                String
  type                  NotificationType
  title                 String
  message               String      @db.Text
  data                  String?     @db.Json
  isRead                Boolean     @default(false)
  readAt                DateTime?
  createdAt             DateTime    @default(now())

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  PURCHASE_CONFIRMATION
  BOOK_APPROVED
  BOOK_REJECTED
  NEW_REVIEW
  PAYMENT_REMINDER
  PROMOTION
  GENERAL
}

// ============================================================
// AUDIT & LOGGING
// ============================================================

model AuditLog {
  id                    String      @id @default(cuid())
  userId                String?
  action                String
  entity                String
  entityId              String?
  changes               String?     @db.Json
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
