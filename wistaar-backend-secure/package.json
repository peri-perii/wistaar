    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
