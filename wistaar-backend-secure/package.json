    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "book-publishing",
