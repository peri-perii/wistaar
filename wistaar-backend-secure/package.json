  "description": "Secure, end-to-end encrypted backend for Wistaar book publishing platform",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
